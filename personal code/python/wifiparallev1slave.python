#!/usr/bin/env python3
import argparse
import socket
import pickle
import threading
import multiprocessing as mp
from wpa_cracker import wpa_check_mic  # Crypto functions
import os

def slave_worker(handshake_data, candidates_chunk):
    """Single worker - checks one chunk"""
    ssid, handshake = handshake_data
    anonce, snonce, mic, ap_mac, client_mac, eapol_prefix = handshake
    
    checked = 0
    for candidate in candidates_chunk:
        if wpa_check_mic(candidate, ssid, anonce, snonce, mic, ap_mac, client_mac, eapol_prefix):
            return True, candidate, checked
        checked += 1
    
    return False, None, checked

